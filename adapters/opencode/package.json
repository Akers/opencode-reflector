{
  "name": "@akers/opencode-reflector-adapter",
  "version": "0.1.0",
  "description": "opencode adapter for opencode-reflector",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
