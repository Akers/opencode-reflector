    "dev": "tsc --watch"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.14.18",
    "@opencode-ai/sdk": "^1.14.18",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  }
}
